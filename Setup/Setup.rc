// TOTP Credential Provider Setup — Resource script
// Embeds TOTPCredentialProvider.dll as a binary resource inside TOTPSetup.exe

#include "setup_resource.h"

// The DLL is embedded as an RCDATA resource.
// At build time, the DLL must exist at this relative path.
// The pre-build event on the Setup project copies it here.
IDR_CREDENTIAL_PROVIDER_DLL RCDATA "TOTPCredentialProvider.dll"
