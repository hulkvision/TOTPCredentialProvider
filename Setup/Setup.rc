// TOTP Credential Provider Setup - Resource script
// Embeds TOTPCredentialProvider.dll and TOTPCredentialProviderFilter.dll
// as binary resources inside TOTPSetup.exe

#include "setup_resource.h"

// The DLLs are embedded as RCDATA resources.
// At build time, the DLLs must exist at these relative paths.
// The pre-build event on the Setup project copies them here.
IDR_CREDENTIAL_PROVIDER_DLL    RCDATA "TOTPCredentialProvider.dll"
IDR_CREDENTIAL_PROVIDER_FILTER RCDATA "TOTPCredentialProviderFilter.dll"
